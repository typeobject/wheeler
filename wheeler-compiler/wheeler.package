package "wheeler.compiler" version "0.1.0" profile "bootstrap-1";
target tool "compiler" root "src/main/wheeler/MinimalCompiler.w" module "wheeler.compiler.driver" source "src/main/wheeler/MinimalCompiler.w" source "src/main/wheeler/compiler/AggregateVerifier.w" source "src/main/wheeler/compiler/Codegen.w" source "src/main/wheeler/compiler/Encoding.w" source "src/main/wheeler/compiler/FunctionVerifier.w" source "src/main/wheeler/compiler/HelperParser.w" source "src/main/wheeler/compiler/InstructionVerifier.w" source "src/main/wheeler/compiler/Ir.w" source "src/main/wheeler/compiler/Opcodes.w" source "src/main/wheeler/compiler/Parser.w" source "src/main/wheeler/compiler/ProofRules.w" source "src/main/wheeler/compiler/ProofVerifier.w" source "src/main/wheeler/compiler/Statements.w" source "src/main/wheeler/compiler/StorageVerifier.w" source "src/main/wheeler/compiler/StringTable.w" source "src/main/wheeler/compiler/Structure.w" source "src/main/wheeler/compiler/Tokens.w" source "src/main/wheeler/compiler/TypeCodes.w" source "src/main/wheeler/compiler/Verifier.w" source "src/main/wheeler/lexer/Scanner.w";
target library "library" root "src/main/wheeler/CompilerLibrary.w" module "wheeler.compiler.library" source "src/main/wheeler/CompilerLibrary.w" source "src/main/wheeler/compiler/AggregateVerifier.w" source "src/main/wheeler/compiler/Codegen.w" source "src/main/wheeler/compiler/Encoding.w" source "src/main/wheeler/compiler/FunctionVerifier.w" source "src/main/wheeler/compiler/HelperParser.w" source "src/main/wheeler/compiler/InstructionVerifier.w" source "src/main/wheeler/compiler/Ir.w" source "src/main/wheeler/compiler/Opcodes.w" source "src/main/wheeler/compiler/Parser.w" source "src/main/wheeler/compiler/ProofRules.w" source "src/main/wheeler/compiler/ProofVerifier.w" source "src/main/wheeler/compiler/Statements.w" source "src/main/wheeler/compiler/StorageVerifier.w" source "src/main/wheeler/compiler/StringTable.w" source "src/main/wheeler/compiler/Structure.w" source "src/main/wheeler/compiler/Tokens.w" source "src/main/wheeler/compiler/TypeCodes.w" source "src/main/wheeler/compiler/Verifier.w" source "src/main/wheeler/lexer/Scanner.w";
