package "wheeler.examples" version "0.1.0" profile "bootstrap-1";
target deployable "binarytree" root "src/main/wheeler/classical/data/BinaryTree.w";
target deployable "bootstrapcontrol" root "src/main/wheeler/classical/control/BootstrapControl.w";
target deployable "coherentoracle" root "src/main/wheeler/quantum/CoherentOracle.w";
target deployable "counter" root "src/main/wheeler/classical/control/Counter.w";
target deployable "finiteenums" root "src/main/wheeler/classical/data/FiniteEnums.w";
target deployable "fixedarrays" root "src/main/wheeler/classical/data/FixedArrays.w" module "examples.collections.fixed_arrays_main" source "src/main/wheeler/classical/data/FixedArrays.w";
target deployable "frozenutf8" root "src/main/wheeler/text/FrozenUtf8.w" module "examples.text.frozen_utf8_main" source "src/main/wheeler/text/FrozenUtf8.w";
target deployable "functionvalues" root "src/main/wheeler/classical/control/FunctionValues.w";
target deployable "hostbinaryinput" root "src/main/wheeler/host/HostBinaryInput.w";
target deployable "hostinput" root "src/main/wheeler/host/HostInput.w";
target deployable "longmap" root "src/main/wheeler/classical/data/LongMap.w" module "examples.collections.long_map_main" source "src/main/wheeler/classical/data/LongMap.w";
target deployable "loopcontrol" root "src/main/wheeler/classical/control/LoopControl.w";
target deployable "moduleexample" root "src/main/wheeler/modules/ModuleMain.w" module "examples.main" source "src/main/wheeler/modules";
target deployable "nativearchive" root "src/main/wheeler/native/NativeArchive.w" module "examples.packages.archive_main" source "src/main/wheeler/native/NativeArchive.w";
target deployable "nativelock" root "src/main/wheeler/native/NativeLock.w" module "examples.packages.lock_main" source "src/main/wheeler/native/NativeLock.w";
target deployable "nativemanifest" root "src/main/wheeler/native/NativeManifest.w" module "examples.packages.main" source "src/main/wheeler/native/NativeManifest.w";
target deployable "nativeplan" root "src/main/wheeler/native/NativePlan.w" module "examples.packages.plan_main" source "src/main/wheeler/native/NativePlan.w";
target deployable "nativesha256" root "src/main/wheeler/native/NativeSha256.w" module "examples.crypto.sha256_main" source "src/main/wheeler/native/NativeSha256.w";
target deployable "nativeverifier" root "src/main/wheeler/native/NativeVerifier.w" module "examples.compiler.native_verifier" source "src/main/wheeler/native/NativeVerifier.w";
target deployable "nativevm" root "src/main/wheeler/native/NativeVm.w" module "examples.runtime.native_vm" source "src/main/wheeler/native/NativeVm.w";
target deployable "nativeworkspace" root "src/main/wheeler/native/NativeWorkspace.w" module "examples.packages.workspace_main" source "src/main/wheeler/native/NativeWorkspace.w";
target deployable "ownedreturns" root "src/main/wheeler/classical/ownership/OwnedReturns.w";
target deployable "qft" root "src/main/wheeler/quantum/QFT.w";
target deployable "qftproof" root "src/main/wheeler/quantum/QFTProof.w" test;
target deployable "quantumcompiler" root "src/main/wheeler/quantum/QuantumCompiler.w";
target deployable "quantumneuralnetwork" root "src/main/wheeler/quantum/QuantumNeuralNetwork.w";
target deployable "quantumoptimizer" root "src/main/wheeler/quantum/QuantumOptimizer.w";
target deployable "records" root "src/main/wheeler/classical/data/Records.w";
target deployable "recursivevalue" root "src/main/wheeler/classical/control/RecursiveValue.w";
target deployable "regionstorage" root "src/main/wheeler/classical/ownership/RegionStorage.w";
target deployable "surfacecode" root "src/main/wheeler/quantum/SurfaceCode.w";
target deployable "utf8lexer" root "src/main/wheeler/text/Utf8Lexer.w" module "examples.lexer.main" source "src/main/wheeler/lexer/Parser.w" source "src/main/wheeler/text/Utf8Lexer.w";
target deployable "variants" root "src/main/wheeler/classical/data/Variants.w";
target deployable "workqueue" root "src/main/wheeler/classical/data/WorkQueue.w" module "examples.queue.main" source "src/main/wheeler/classical/data/WorkQueue.w";
dependency normal "wheeler.compiler" version "=0.1.0";
dependency normal "wheeler.core" version "=0.1.0";
dependency normal "wheeler.packages" version "=0.1.0";
dependency normal "wheeler.runtime" version "=0.1.0";
capability "build.read" path "src/main/wheeler/**";
capability "build.write" path "build/**";
