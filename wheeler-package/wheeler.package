package "wheeler.packages" version "0.1.0" profile "bootstrap-1";
target library "library" root "src/main/wheeler/PackageLibrary.w" module "wheeler.packages.library" source "src/main/wheeler/PackageLibrary.w" source "src/main/wheeler/crypto/Sha256.w" source "src/main/wheeler/packages/Archive.w" source "src/main/wheeler/packages/LineEmitter.w" source "src/main/wheeler/packages/Lock.w" source "src/main/wheeler/packages/Manifest.w" source "src/main/wheeler/packages/ManifestEmitter.w" source "src/main/wheeler/packages/ManifestTokens.w" source "src/main/wheeler/packages/Names.w" source "src/main/wheeler/packages/Paths.w" source "src/main/wheeler/packages/Plan.w" source "src/main/wheeler/packages/PlanIdentity.w" source "src/main/wheeler/packages/Semver.w" source "src/main/wheeler/packages/Workspace.w";
dependency normal "wheeler.compiler" version "=0.1.0";
dependency normal "wheeler.core" version "=0.1.0";
capability "build.read" path "src/main/wheeler/**";
capability "build.write" path "out/**";
